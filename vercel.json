{
  "rootDirectory": "frontend",
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "build",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "https://pgmt-api.onrender.com"
  },
  "routes": [
    {
      "src": "/(.*)",
      "methods": ["GET"],
      "dest": "/index.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
